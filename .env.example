# GSD Node - Environment Configuration

# ==============================================================================
# REQUIRED
# ==============================================================================

# WebSocket server URL (must use wss://)
SERVER_URL=wss://your-server.example.com/ws

# Bearer token for server authentication
SERVER_TOKEN=your-secret-token

# ==============================================================================
# OPTIONAL
# ==============================================================================

# Comma-separated list of project names this node can handle
# Empty means no projects advertised to server
# PROJECTS=my-project,another-project

# WebSocket heartbeat ping interval in seconds (default: 30)
# HEARTBEAT_INTERVAL_SECS=30

# Working directory for Claude CLI (default: current directory)
# CLAUDE_WORKING_DIR=/path/to/projects

# Paths Claude is allowed to access (comma-separated)
# ALLOWED_PATHS=/path/to/project1,/path/to/project2

# Audit log path (default: /tmp/gsd-node-audit.log)
# AUDIT_LOG_PATH=/tmp/gsd-node-audit.log
